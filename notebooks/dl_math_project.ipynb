   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# 6.1 Search Space"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 7,
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Vocab size: 20000\n",
      "Search space defined!\n"
     ]
    }
   ],
   "source": [
    "vocab_size = int(X_train.max()) + 1\n",
    "print(f\"Vocab size: {vocab_size}\")\n",
    "\n",
    "def build_hp_model(hp):\n",
    "    \"\"\"\n",
    "    Build LSTM model with tunable hyperparameters for keras_tuner.\n",
    "\n",
    "    Args:\n",
    "        hp: keras_tuner HyperParameters object that defines the search space.\n",
    "\n",
    "    Returns:\n",
    "        keras.Model: Compiled BiLSTM model with sampled hyperparameters.\n",
    "    \"\"\"\n",
    "    return build_lstm_model(\n",
    "        vocab_size=vocab_size,\n",
    "        embedding_dim=hp.Choice(\"embedding_dim\", [64, 128]),\n",
    "        lstm_units=hp.Choice(\"lstm_units\", [32, 64, 128]),\n",
    "        dropout_rate=hp.Float(\"dropout_rate\", min_value=0.3, \n",
    "                              max_value=0.5, step=0.1),\n",
    "        learning_rate=hp.Choice(\"learning_rate\", [1e-3, 1e-4]),\n",
    "    )\n",
    "\n",
    "print(\"Search space defined!\")"
   ]
  },
