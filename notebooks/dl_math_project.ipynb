    "from transformers import DistilBertTokenizerFast\n",
    "import numpy as np\n",
    "\n",
    "BERT_MODEL_NAME = \"distilbert-base-uncased\"\n",
    "MAX_LEN = 128\n",
    "\n",
    "# Load tokenizer\n",
    "tokenizer_bert = DistilBertTokenizerFast.from_pretrained(BERT_MODEL_NAME)\n",
    "\n",
    "# Load test data\n",
    "test_df_bert = pd.read_csv(\"../data/test.csv\")\n",
    "test_df_bert[\"text\"] = test_df_bert[\"title\"].astype(str) + \" \" + test_df_bert[\"description\"].astype(str)\n",
    "test_labels_bert = (pd.to_numeric(test_df_bert[\"class_index\"], errors=\"coerce\").fillna(1).values - 1).astype(int)\n",
    "\n",
    "# Tokenize\n",
    "print(\"Tokenizing test data...\")\n",
    "test_encodings = tokenizer_bert(\n",
    "    list(test_df_bert[\"text\"]),\n",
    "    truncation=True,\n",
    "    padding=True,\n",
    "    max_length=MAX_LEN,\n",
    "    return_tensors=\"tf\"\n",
    ")\n",
    "print(f\"Done! Shape: {test_encodings['input_ids'].shape}\")\n"
   ]
