    "    padding=True,\n",
    "    max_length=MAX_LEN,\n",
    "    return_tensors='tf'\n",
    ")\n",
    "\n",
    "print(\"Tokenization done!\")\n",
    "print(f\"Input IDs shape: {train_encodings['input_ids'].shape}\")"
