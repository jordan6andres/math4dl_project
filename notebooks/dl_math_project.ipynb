   "source": [
    "# BERT prediction in batches\n",
    "print(\"Running BERT predictions...\")\n",
    "BATCH_SIZE = 32\n",
    "n_samples = len(test_labels_bert)\n",
    "all_preds = []\n",
    "\n",
    "for i in range(0, n_samples, BATCH_SIZE):\n",
    "    batch_ids  = test_encodings[\"input_ids\"][i:i+BATCH_SIZE]\n",
    "    batch_mask = test_encodings[\"attention_mask\"][i:i+BATCH_SIZE]\n",
    "    \n",
    "    outputs = infer_fn(\n",
    "        input_ids=batch_ids,\n",
    "        attention_mask=batch_mask\n",
    "    )\n",
    "    \n",
    "    preds = np.argmax(outputs[\"logits\"].numpy(), axis=1)\n",
    "    all_preds.extend(preds)\n",
    "    \n",
    "    if i % 1000 == 0:\n",
    "        print(f\"  Processed {i}/{n_samples}...\")\n",
    "\n",
    "bert_y_pred = np.array(all_preds)\n",
    "bert_y_true = test_labels_bert\n",
    "\n",
    "from sklearn.metrics import accuracy_score\n",
    "bert_test_acc = accuracy_score(bert_y_true, bert_y_pred)\n",
    "print(f\"\\nBERT Test Accuracy: {bert_test_acc:.4f} ({bert_test_acc*100:.2f}%)\")"
   ]
